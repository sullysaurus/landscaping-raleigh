---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafMark from '../components/LeafMark.astro';
import ArrowIcon from '../components/ArrowIcon.astro';

const headlineKeywords = [
  { keyword: 'landscaping raleigh nc', volume: '1,300', role: 'Homepage', width: 100 },
  { keyword: 'landscape design raleigh nc', volume: '320', role: 'Service page', width: 47 },
  { keyword: 'landscape lighting raleigh nc', volume: '110', role: 'Service page', width: 29 },
  { keyword: 'hardscaping raleigh nc', volume: '90', role: 'Service page', width: 25 },
  { keyword: 'native plants raleigh nc', volume: '30', role: 'Authority topic', width: 15 },
];

const opportunityNotes = [
  { number: '01', label: 'Lead with the category', copy: 'The homepage has the largest local opportunity. It should clearly say Raleigh landscaping and send visitors into the right specialty.' },
  { number: '02', label: 'Win with expertise', copy: 'Norman’s horticulture, botanical-garden and design experience is the advantage generic contractors cannot easily copy.' },
  { number: '03', label: 'Prove, then explain', copy: 'Strong service pages and real project stories should come before a large volume of blog posts.' },
];

const launchTargets = [
  { value: '32+', label: 'indexable releases', copy: 'Eight anchor pages plus at least two search-led posts each week for twelve weeks.' },
  { value: '8', label: 'anchor website pages', copy: 'Homepage, five priority services, Norman’s expert profile and a project hub.' },
  { value: '24+', label: 'search-led posts', copy: 'Useful guides, project stories and timely answers that lead to a relevant service.' },
  { value: '4', label: 'project media packages', copy: 'Before-and-after photography or short video prepared for the website, Google and social.' },
];

const servicePages = [
  {
    priority: '01',
    status: 'Build first',
    title: 'Landscape design',
    url: '/landscape-design-raleigh/',
    keyword: 'landscape design raleigh nc',
    volume: '320 searches / month',
    purpose: 'The flagship service page: process, expertise, project proof, cost factors and a consultation invitation.',
    proof: 'Plans, credentials, before/after work',
  },
  {
    priority: '02',
    status: 'Build first',
    title: 'Drainage & rain gardens',
    url: '/drainage-rain-gardens-raleigh/',
    keyword: 'yard drainage raleigh nc',
    volume: 'Problem-led opportunity',
    purpose: 'Connect standing water, Raleigh clay soil and runoff problems to thoughtful, attractive solutions.',
    proof: 'Water diagnosis, rain-garden project',
  },
  {
    priority: '03',
    status: 'Build first',
    title: 'Hardscaping',
    url: '/hardscaping-raleigh/',
    keyword: 'hardscaping raleigh nc',
    volume: '90 searches / month',
    purpose: 'Show patios, walls, paths and fire features as lasting parts of a complete living garden.',
    proof: 'Materials, drainage, finished projects',
  },
  {
    priority: '04',
    status: 'Build next',
    title: 'Native garden design',
    url: '/native-garden-design-raleigh/',
    keyword: 'native plant landscaping raleigh nc',
    volume: 'Specialist opportunity',
    purpose: 'Own the plant-focused position homeowners say is difficult to find in the Triangle.',
    proof: 'Plant palettes, site conditions, results',
  },
  {
    priority: '05',
    status: 'Build next',
    title: 'Landscape lighting',
    url: '/landscape-lighting-raleigh/',
    keyword: 'landscape lighting raleigh nc',
    volume: '110 searches / month',
    purpose: 'Capture measurable demand with a visual page about subtle, useful nighttime design.',
    proof: 'Dusk photography, fixtures, process',
  },
];

const calendar = [
  {
    month: 'Month 1',
    focus: 'Build the foundation and flagship',
    outcome: 'Measurement is live and the two most important customer journeys have dedicated pages.',
    releases: ['Homepage search refresh', 'Landscape design service page', 'Drainage & rain gardens page', 'About Norman expert profile'],
    posts: ['8 search-led posts', 'Woodland project story', 'Design-cost and hiring guides', 'Raleigh idea and FAQ content'],
    systems: ['Search Console + sitemap', 'Analytics + inquiry tracking', 'Google profile + review workflow'],
  },
  {
    month: 'Month 2',
    focus: 'Capture high-intent demand',
    outcome: 'The site covers valuable project work and begins answering late-stage buying questions.',
    releases: ['Hardscaping service page', 'Native garden design page', 'Projects and before/after hub'],
    posts: ['8 search-led posts', 'Standing-water and drainage guides', 'Clay-soil and native-shade guides', 'Drainage transformation story'],
    systems: ['Contextual internal links', 'Service, article + breadcrumb schema', 'First evidence-led performance review'],
  },
  {
    month: 'Month 3',
    focus: 'Expand authority and improve',
    outcome: 'A complete first content cluster is live, measured and ready for the next-quarter decision.',
    releases: ['Landscape lighting service page'],
    posts: ['8 search-led posts', 'Designer vs. architect guide', 'Rainwater Rewards and plant guides', 'Patio + native planting story'],
    systems: ['Search Console query refresh', 'Title + opening improvements', '90-day results and next-quarter plan'],
  },
];

const articleIdeas = [
  { rank: '01', title: 'How to fix standing water in a Raleigh yard', search: '170 monthly searches', score: '8.8', route: 'Drainage inquiries' },
  { rank: '02', title: 'What does landscape design cost in Raleigh?', search: 'High buying intent', score: '8.6', route: 'Design consultations' },
  { rank: '03', title: 'Landscape designer vs. landscape architect', search: '260 monthly searches', score: '8.3', route: 'Design consultations' },
  { rank: '04', title: 'Best plants for Raleigh clay soil', search: '320-topic opportunity', score: '8.2', route: 'Garden design' },
  { rank: '05', title: 'Raleigh Rainwater Rewards: a homeowner guide', search: '40 local searches', score: '8.1', route: 'Rain gardens' },
  { rank: '06', title: 'Low-maintenance landscaping ideas for Raleigh', search: '2,400 broad searches', score: '7.9', route: 'Landscape design' },
];

const ownerInputs = [
  'The three project types Garden & Art most wants to sell',
  'A realistic minimum project size and profitable service radius',
  'Before-and-after photos with the city, problem and result',
  'The questions and concerns homeowners ask most often',
  'Permissioned reviews and short customer quotations',
  'Confirmed credentials, business hours and service-area policy',
];

const scorecard = [
  { metric: 'Relevant top-30 keywords', baseline: '0', day90: '5+', note: 'Third-party visibility signal' },
  { metric: 'Useful indexable pages', baseline: '2', day90: '32+', note: 'Eight anchors plus 24+ useful posts' },
  { metric: 'Priority service pages', baseline: '0', day90: '5', note: 'All Tier 1 commercial opportunities' },
  { metric: 'Detailed project stories', baseline: '0', day90: '3', note: 'Dependent on photos and owner detail' },
  { metric: 'Organic inquiry tracking', baseline: 'Not confirmed', day90: 'Live', note: 'Forms, phone taps and email clicks' },
];
---

<BaseLayout
  title="90-Day SEO Growth Plan | Garden & Art Landscapes"
  description="The evidence-led 90-day SEO growth plan and client scorecard for Garden & Art Landscapes."
  noindex
>
  <a class="skip-link" href="#roadmap">Skip to the roadmap</a>
  <main class="roadmap" id="roadmap">
    <header class="report-header">
      <a class="report-brand" href="/" aria-label="Garden and Art Landscapes home">
        <LeafMark />
        <span>Garden <i>&</i> Art Landscapes</span>
      </a>
      <nav aria-label="Roadmap sections">
        <a href="#opportunity">Opportunity</a>
        <a href="#pages">Pages</a>
        <a href="#calendar">90 days</a>
        <a href="#scorecard">Scorecard</a>
        <a href="#owner">Your part</a>
      </nav>
      <div class="report-date"><span>90-day SEO growth plan</span><strong>July 2026</strong></div>
    </header>

    <section class="report-hero">
      <div class="hero-copy">
        <p class="eyebrow light">The first 90 days</p>
        <h1>Build the local<br /><em>search engine.</em></h1>
        <p>Garden & Art already has the expertise and finished work. In three focused months, we turn it into a connected system of service pages, project proof, useful local guidance and measurable inquiry paths.</p>
        <a class="hero-link" href="#calendar">See the 90-day build <ArrowIcon /></a>
      </div>
      <aside class="north-star">
        <span>North star</span>
        <strong>More qualified Raleigh homeowners—not simply more website traffic.</strong>
        <p>Every release must help the right person understand the work, trust Norman’s expertise and start a useful conversation.</p>
      </aside>
      <div class="contour contour-one"></div>
      <div class="contour contour-two"></div>
    </section>

    <section class="position-strip" aria-label="SEO strategy summary">
      <span>Position the business as</span>
      <strong>A horticulture-led landscape design & build specialist</strong>
      <small>Not a generic mowing company</small>
    </section>

    <section class="launch-strip" aria-label="90-day production targets">
      {launchTargets.map((target) => (
        <article><strong>{target.value}</strong><div><h2>{target.label}</h2><p>{target.copy}</p></div></article>
      ))}
    </section>

    <section class="opportunity" id="opportunity">
      <header class="section-heading">
        <div><p class="eyebrow">What people search for</p><h2>Demand points to a<br /><em>clear starting place.</em></h2></div>
        <p>Search volume shows the homepage and landscape-design page carry the broadest local opportunities. Specialty pages make the company more relevant when homeowners have a specific need.</p>
      </header>

      <div class="opportunity-grid">
        <div class="keyword-chart" aria-label="Monthly keyword search volume comparison">
          <div class="chart-note"><span>Approximate monthly U.S. searches</span><small>Keywords Everywhere · July 2026</small></div>
          {headlineKeywords.map((item) => (
            <article>
              <div class="keyword-meta"><strong>{item.keyword}</strong><span>{item.role}</span></div>
              <div class="bar-line"><i style={`--bar-width:${item.width}%`}></i><b>{item.volume}</b></div>
            </article>
          ))}
          <p class="chart-caveat">Search volume is directional. Low-volume local phrases can still create valuable projects; paid competition is not the same as organic difficulty.</p>
        </div>

        <aside class="baseline-card">
          <span>Today’s search baseline</span>
          <strong>0</strong>
          <h3>relevant top-30 keywords detected</h3>
          <p>This is an early-site baseline, not a verdict. The redesigned site has the technical groundwork; it now needs focused pages and time to earn visibility.</p>
        </aside>
      </div>

      <div class="opportunity-notes">
        {opportunityNotes.map((note) => (
          <article><span>{note.number}</span><h3>{note.label}</h3><p>{note.copy}</p></article>
        ))}
      </div>
    </section>

    <section class="page-plan" id="pages">
      <header class="section-heading inverse">
        <div><p class="eyebrow light">The commercial foundation</p><h2>Five focused pages.<br /><em>One clear job each.</em></h2></div>
        <p>Instead of asking one homepage to rank for every service, each valuable offer gets enough room to explain the problem, process, proof and next step.</p>
      </header>

      <div class="page-list">
        {servicePages.map((page) => (
          <article>
            <span class="page-number">{page.priority}</span>
            <div class="page-main">
              <div class="page-label"><b>{page.status}</b><small>{page.url}</small></div>
              <h3>{page.title}</h3>
              <p>{page.purpose}</p>
            </div>
            <div class="page-data">
              <small>Target search</small><strong>{page.keyword}</strong><span>{page.volume}</span>
            </div>
            <div class="page-proof"><small>Proof needed</small><span>{page.proof}</span></div>
          </article>
        ))}
      </div>
    </section>

    <section class="calendar-section" id="calendar">
      <header class="section-heading">
        <div><p class="eyebrow">The 90-day production plan</p><h2>Three focused sprints.<br /><em>Thirty-two useful releases.</em></h2></div>
        <p>Eight anchor pages establish the commercial map. A two-posts-a-week publishing rhythm builds supporting depth. Owner detail, photography and approval remain the quality gates.</p>
      </header>

      <div class="calendar-grid">
        {calendar.map((item, index) => (
          <article>
            <div class="month-marker"><span>{item.month}</span><i>{String(index + 1).padStart(2, '0')}</i></div>
            <strong>{item.focus}</strong>
            <p class="month-outcome">{item.outcome}</p>
            <div class="month-list"><small>Anchor releases</small>{item.releases.map((release) => <span>{release}</span>)}</div>
            <div class="month-list posts"><small>Weekly publishing</small>{item.posts.map((post) => <span>{post}</span>)}</div>
            <div class="month-list systems"><small>Systems and optimization</small>{item.systems.map((system) => <span>{system}</span>)}</div>
          </article>
        ))}
      </div>
      <p class="pace-note"><strong>Production rule:</strong> if photos or expert input delay a project story, advance the next evidence-ready guide. Never replace missing proof with thin copy.</p>
    </section>

    <section class="content-queue">
      <header class="queue-heading">
        <div><p class="eyebrow light">The first editorial queue</p><h2>Helpful answers that<br /><em>lead somewhere useful.</em></h2></div>
        <p>These guides attract homeowners before they choose a contractor. Each one answers a real question and points naturally toward a relevant service.</p>
      </header>
      <div class="queue-table" role="table" aria-label="Prioritized article ideas">
        <div class="queue-row queue-head" role="row"><span>Rank</span><span>Topic</span><span>Search signal</span><span>Strategy score</span><span>Leads to</span></div>
        {articleIdeas.map((idea) => (
          <div class="queue-row" role="row">
            <span>{idea.rank}</span><strong>{idea.title}</strong><span>{idea.search}</span><b>{idea.score}</b><span>{idea.route}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="quality-section">
      <div class="quality-lead">
        <p class="eyebrow">What makes this work</p>
        <h2>Real experience is<br /><em>the content strategy.</em></h2>
        <p>The website should feel like Norman walking a homeowner through a property: observant, specific, practical and visually alive.</p>
      </div>
      <div class="quality-list">
        <article><span>01</span><div><strong>Show the work</strong><p>Before, process and after photographs with the actual problem and result.</p></div></article>
        <article><span>02</span><div><strong>Explain the judgment</strong><p>Why a plant, material or drainage approach fit that particular Raleigh site.</p></div></article>
        <article><span>03</span><div><strong>Use verified proof</strong><p>Credentials, license, customer words and firsthand project details.</p></div></article>
        <article><span>04</span><div><strong>Make the next step clear</strong><p>Every page should lead to one appropriate conversation, not a maze of calls to action.</p></div></article>
      </div>
    </section>

    <section class="scorecard-section" id="scorecard">
      <header class="section-heading">
        <div><p class="eyebrow">How the dashboard earns its name</p><h2>Measure shipped work<br />and <em>market response.</em></h2></div>
        <p>The first 90 days need leading indicators because rankings and leads lag publication. Search Console becomes the primary source once enough first-party data exists.</p>
      </header>
      <div class="scorecard-table" role="table" aria-label="90-day SEO scorecard">
        <div class="scorecard-row scorecard-head" role="row"><span>Metric</span><span>July baseline</span><span>Day-90 target</span><span>What it means</span></div>
        {scorecard.map((item) => (
          <div class="scorecard-row" role="row"><strong>{item.metric}</strong><span>{item.baseline}</span><b>{item.day90}</b><span>{item.note}</span></div>
        ))}
      </div>
      <div class="measurement-grid">
        <article><span>Visibility</span><strong>Queries, impressions, ranking page and position</strong></article>
        <article><span>Engagement</span><strong>Organic entrances, useful visits and page depth</strong></article>
        <article><span>Conversion</span><strong>Calls, email clicks and completed inquiry forms</strong></article>
        <article><span>Business value</span><strong>Qualified leads, estimates and booked revenue</strong></article>
      </div>
    </section>

    <section class="owner-section" id="owner">
      <header>
        <p class="eyebrow light">Norman’s part</p>
        <h2>The raw material only<br /><em>the owner can provide.</em></h2>
        <p>Danny can shape, design and publish the content. These inputs keep it accurate, personal and impossible for a generic competitor to imitate.</p>
      </header>
      <div class="owner-checklist">
        {ownerInputs.map((input, index) => (
          <label><input type="checkbox" /><span><i>{String(index + 1).padStart(2, '0')}</i>{input}</span></label>
        ))}
      </div>
      <aside class="owner-callout">
        <span>Best first handoff</span>
        <strong>Choose one great landscape-design project.</strong>
        <p>Gather 8–12 photos, the location, what was wrong, what changed and one customer quote. That single project can support the first service page, case study and social posts.</p>
      </aside>
    </section>

    <section class="guardrails">
      <p class="eyebrow">What we will not do</p>
      <div>
        <p><span>×</span>Publish dozens of copy-and-paste city pages</p>
        <p><span>×</span>Chase traffic unrelated to profitable work</p>
        <p><span>×</span>Stuff “Raleigh” into every sentence</p>
        <p><span>×</span>Present generic AI copy as local expertise</p>
      </div>
    </section>

    <footer class="report-footer">
      <div><LeafMark /><p><strong>Garden & Art Landscapes</strong><span>90-day SEO growth plan · July 2026</span></p></div>
      <nav aria-label="Report links"><a href="/">View website</a><a href="/proposal/">View growth proposal</a></nav>
      <p>Prepared by <a href="https://dannysullivan.ai" target="_blank" rel="noopener noreferrer">Danny Sullivan</a></p>
    </footer>
  </main>

  <style>
    :global(body) { background: #dcd6c8; }
    .roadmap { background: var(--paper); box-shadow: var(--shadow-lift); margin: 24px auto; max-width: 1280px; overflow: hidden; }
    .report-header { align-items: center; background: rgba(245,241,232,.96); border-bottom: 1px solid var(--line); display: grid; gap: 28px; grid-template-columns: 1fr auto 1fr; min-height: 78px; padding: 0 48px; position: relative; z-index: 5; }
    .report-brand { align-items: center; display: flex; font-family: var(--serif); font-size: 19px; text-decoration: none; }
    .report-brand :global(svg) { color: var(--forest); height: 30px; margin-right: 9px; width: 30px; }
    .report-brand i { color: var(--clay); font-weight: 400; }
    .report-header nav { display: flex; gap: 26px; }
    .report-header nav a { font-size: 8px; font-weight: 700; letter-spacing: .12em; text-decoration: none; text-transform: uppercase; }
    .report-header nav a:hover { color: var(--clay-dark); }
    .report-date { align-items: flex-end; display: flex; flex-direction: column; }
    .report-date span, .report-date strong { font-size: 8px; letter-spacing: .12em; text-transform: uppercase; }
    .report-date span { color: var(--clay-dark); }
    .report-date strong { color: var(--ink-muted); font-weight: 500; margin-top: 3px; }

    .report-hero { background: var(--forest-deep); color: var(--white); display: grid; gap: 72px; grid-template-columns: 1.35fr .65fr; isolation: isolate; overflow: hidden; padding: 82px 64px 74px; position: relative; }
    .hero-copy { position: relative; z-index: 2; }
    .hero-copy h1 { color: var(--white); font-size: clamp(60px, 7vw, 94px); }
    .hero-copy > p:nth-of-type(2) { color: rgba(255,253,247,.72); font-size: 15px; line-height: 1.75; margin: 30px 0 34px; max-width: 720px; }
    .hero-link { align-items: center; color: var(--white); display: inline-flex; font-size: 10px; font-weight: 700; gap: 26px; letter-spacing: .12em; text-decoration: none; text-transform: uppercase; }
    .hero-link :global(svg) { color: var(--clay); height: 24px; transition: transform .2s ease; width: 24px; }
    .hero-link:hover :global(svg) { transform: translateX(5px); }
    .north-star { align-self: end; border-left: 1px solid rgba(255,253,247,.2); padding: 8px 0 8px 28px; position: relative; z-index: 2; }
    .north-star > span { color: var(--clay); font-size: 9px; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; }
    .north-star > strong { display: block; font-family: var(--serif); font-size: 28px; font-weight: 400; line-height: 1.08; margin-top: 22px; }
    .north-star p { color: rgba(255,253,247,.55); font-size: 11px; line-height: 1.65; margin: 20px 0 0; }
    .contour { border: 1px solid rgba(194,203,183,.08); border-radius: 48% 52% 63% 37%; position: absolute; transform: rotate(-14deg); z-index: 0; }
    .contour-one { height: 430px; right: -120px; top: -150px; width: 540px; }
    .contour-two { border-color: rgba(201,111,74,.12); height: 500px; right: -150px; top: -185px; width: 620px; }
    .position-strip { align-items: center; background: var(--clay); color: var(--white); display: grid; gap: 24px; grid-template-columns: 180px 1fr auto; padding: 18px 64px; }
    .position-strip span, .position-strip small { font-size: 8px; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
    .position-strip strong { font-family: var(--serif); font-size: 22px; font-weight: 400; }
    .position-strip small { color: rgba(255,253,247,.7); }
    .launch-strip { background: var(--paper-deep); border-bottom: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); }
    .launch-strip article { align-items: start; border-right: 1px solid var(--line); display: grid; gap: 14px; grid-template-columns: auto 1fr; padding: 28px 24px; }
    .launch-strip article:last-child { border-right: 0; }
    .launch-strip article > strong { color: var(--clay-dark); font-family: var(--serif); font-size: 48px; font-weight: 400; letter-spacing: -.05em; line-height: .85; }
    .launch-strip h2 { color: var(--forest); font-family: var(--serif); font-size: 18px; font-weight: 400; line-height: 1.05; margin: 0; }
    .launch-strip p { color: var(--ink-muted); font-size: 8px; line-height: 1.55; margin: 7px 0 0; }

    .opportunity, .calendar-section { padding: 78px 64px; }
    .section-heading { align-items: end; display: grid; gap: 72px; grid-template-columns: 1.2fr .8fr; }
    .section-heading h2, .queue-heading h2, .quality-lead h2, .owner-section header h2 { font-size: clamp(44px, 5vw, 66px); }
    .section-heading > p, .queue-heading > p { color: var(--ink-soft); font-size: 12px; line-height: 1.75; margin: 0; }
    .opportunity-grid { display: grid; gap: 0; grid-template-columns: 1.5fr .5fr; margin-top: 52px; }
    .keyword-chart { border: 1px solid var(--line); padding: 28px 32px 24px; }
    .chart-note { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding-bottom: 18px; }
    .chart-note span { font-size: 10px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; }
    .chart-note small { color: var(--ink-muted); font-size: 8px; }
    .keyword-chart article { border-bottom: 1px solid var(--line); padding: 16px 0; }
    .keyword-meta { align-items: center; display: flex; justify-content: space-between; }
    .keyword-meta strong { font-size: 11px; font-weight: 600; }
    .keyword-meta span { color: var(--ink-muted); font-size: 8px; letter-spacing: .08em; text-transform: uppercase; }
    .bar-line { align-items: center; display: grid; gap: 14px; grid-template-columns: 1fr 42px; margin-top: 9px; }
    .bar-line::before { background: rgba(29,40,34,.07); content: ''; grid-column: 1; grid-row: 1; height: 4px; }
    .bar-line i { background: var(--clay); grid-column: 1; grid-row: 1; height: 4px; width: var(--bar-width); }
    .bar-line b { color: var(--forest); font-family: var(--serif); font-size: 17px; font-weight: 500; text-align: right; }
    .chart-caveat { color: var(--ink-muted); font-size: 9px; line-height: 1.55; margin: 20px 0 0; }
    .baseline-card { background: var(--paper-deep); border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); border-top: 1px solid var(--line); display: flex; flex-direction: column; padding: 28px; }
    .baseline-card > span { color: var(--clay-dark); font-size: 9px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
    .baseline-card > strong { color: var(--forest); font-family: var(--serif); font-size: 112px; font-weight: 400; letter-spacing: -.08em; line-height: .85; margin-top: 58px; }
    .baseline-card h3 { font-family: var(--serif); font-size: 24px; font-weight: 400; line-height: 1.05; margin: 14px 0 0; }
    .baseline-card p { color: var(--ink-soft); font-size: 10px; line-height: 1.7; margin: auto 0 0; }
    .opportunity-notes { border-left: 1px solid var(--line); display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 32px; }
    .opportunity-notes article { border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); border-top: 1px solid var(--line); padding: 24px; }
