---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafMark from '../components/LeafMark.astro';

const scores = [
  { label: 'Technical SEO', value: 82 },
  { label: 'On-page SEO', value: 82 },
  { label: 'Structured data', value: 82 },
  { label: 'Content quality', value: 72 },
  { label: 'Images', value: 65 },
  { label: 'Performance', value: 60 },
];

const completed = [
  'GitHub and Netlify production connected to main',
  'Correct production domain and canonical URLs',
  'Search-focused title, description and Raleigh hero copy',
  'Open Graph and social sharing metadata',
  'Robots file and XML sitemap',
  'Local business, founder, website and service schema',
  'Privacy page and inquiry-form privacy notice',
  'Image alt text, dimensions and stable layouts',
  'Faster hero and optimized lighting image',
  'Noindex protection for private utility pages',
  'Security headers and asset caching',
  'Direct apex-to-www redirects',
  'Clear NC contractor license wording',
];

const nextMoves = [
  {
    number: '01',
    title: 'Connect Google and the dashboard',
    owner: 'Danny + Norman',
    copy: 'Connect Analytics, Search Console and the Google Business Profile so traffic, searches, calls and completed work appear in one client view.',
  },
  {
    number: '02',
    title: 'Build the eight new pages',
    owner: 'First 90 days',
    copy: 'Publish focused service pages, Norman’s story and a before-and-after project hub so each important service has a clear place to be found.',
  },
  {
    number: '03',
    title: 'Start the weekly publishing system',
    owner: 'At least 2 posts weekly',
    copy: 'Publish keyword-based blog posts, cross-post them to Facebook, Instagram and Google, and support them with Danny’s project photography and video.',
  },
];

const resultCards = [
  { label: 'Website traffic', value: 'Ready to connect', source: 'Google Analytics', copy: 'Visitors, popular pages and whether traffic is growing.' },
  { label: 'Google searches', value: 'Ready to connect', source: 'Search Console', copy: 'The exact searches people use and which pages they find.' },
  { label: 'Calls & inquiries', value: 'Tracking planned', source: 'Website actions', copy: 'Contact forms, phone taps and email clicks from the website.' },
  { label: 'Work completed', value: 'Tracker ready', source: 'Weekly update', copy: 'Pages, blog posts, social posts, emails, photos and reviews.' },
];

const programItems = [
  { label: 'Website expansion', target: '8 new pages', status: 'Planned' },
  { label: 'Keyword blog content', target: '2+ posts each week', status: 'Planned' },
  { label: 'Facebook · Instagram · Google', target: 'Cross-post each strong idea', status: 'Planned' },
  { label: 'Google Business Profile', target: 'Build and maintain', status: 'Danny coordinating' },
  { label: 'Email list & review campaign', target: 'Set up, import and connect', status: 'Danny coordinating' },
  { label: 'Before/after photos & video', target: 'Capture project proof', status: 'Schedule project' },
  { label: 'Analytics & search reporting', target: 'Dashboard + weekly report', status: 'Danny coordinating' },
];
---

<BaseLayout
  title="SEO Progress Dashboard | Garden & Art Landscapes"
  description="A client progress dashboard for the Garden & Art Landscapes growth program."
  noindex
>
  <main class="seo-report">
    <header class="report-header">
      <a class="report-brand" href="/" aria-label="Garden and Art Landscapes home">
        <LeafMark />
        <span>Garden <i>&</i> Art Landscapes</span>
      </a>
      <div><span>SEO field report</span><strong>Updated July 14, 2026</strong></div>
    </header>

    <section class="report-hero">
      <div class="hero-message">
        <p class="eyebrow">Current position</p>
        <h1>The groundwork is ready.<br /><em>Now we build visibility.</em></h1>
        <p>The website’s core SEO foundation is in place. The next gains come from connecting Google, confirming the business information and consistently publishing proof of the work.</p>
      </div>
      <div class="growth-score" aria-label="SEO health score 73 out of 100">
        <div class="ring ring-one"></div><div class="ring ring-two"></div><div class="ring ring-three"></div>
        <div class="score-copy"><strong>73</strong><span>out of 100</span><small>Live production</small></div>
      </div>
    </section>

    <section class="growth-path" aria-label="SEO growth stages">
      <article class="complete"><span>01</span><div><strong>Groundwork</strong><small>Technical foundation</small></div><b>Complete</b></article>
      <article class="active"><span>02</span><div><strong>Visibility</strong><small>Google + local proof</small></div><b>Next</b></article>
      <article><span>03</span><div><strong>Growth</strong><small>Content + measurement</small></div><b>Planned</b></article>
    </section>

    <section class="live-results" aria-labelledby="results-title">
      <div class="section-title">
        <div><p class="eyebrow">Live business results</p><h2 id="results-title">One place to see if the work is working.</h2></div>
        <span>Data appears after Google access is connected</span>
      </div>
      <div class="result-card-grid">
        {resultCards.map((card) => (
          <article>
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.copy}</p>
            <small>{card.source}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="program-tracker" aria-labelledby="tracker-title">
      <header>
        <p class="eyebrow light">90-day work tracker</p>
        <h2 id="tracker-title">The plan, the target<br /><em>and the current status.</em></h2>
        <p>Once the program begins, this section will show completed pages, weekly posts, photo and video work, review outreach and the next action.</p>
      </header>
      <div class="tracker-list">
        {programItems.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div><strong>{item.label}</strong><small>{item.target}</small></div>
            <b>{item.status}</b>
          </article>
        ))}
      </div>
    </section>

    <section class="report-grid">
      <div class="score-panel">
        <div class="section-title"><p class="eyebrow">Health by area</p><span>Directional until Google data is connected</span></div>
        <div class="score-list">
          {scores.map((score) => (
            <div class="score-row">
              <span>{score.label}</span>
              <div class="score-track" aria-hidden="true"><i style={`width:${score.value}%`}></i></div>
              <strong>{score.value}</strong>
            </div>
          ))}
        </div>
      </div>

      <aside class="measurement-note">
        <p class="eyebrow light">What the score means</p>
        <strong>Strong foundation.<br />Limited real-world data.</strong>
        <p>Search Console, Analytics and Business Profile insights will replace assumptions with actual searches, calls and inquiries after they are connected.</p>
      </aside>
    </section>

    <section class="completed-work">
      <div class="section-title"><p class="eyebrow">Fixed and live</p><span>{completed.length} improvements completed</span></div>
      <div class="completed-list">
        {completed.map((item, index) => <p><span>{String(index + 1).padStart(2, '0')}</span><i>✓</i>{item}</p>)}
      </div>
    </section>

    <section class="next-section">
      <div class="section-title"><p class="eyebrow">What comes next</p><span>Highest-value work, in order</span></div>
      <div class="next-list">
        {nextMoves.map((move) => (
          <article>
            <span>{move.number}</span>
            <div><h2>{move.title}</h2><p>{move.copy}</p></div>
            <small>{move.owner}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="cadence-section">
      <div class="section-title"><p class="eyebrow">Recommended rhythm</p><span>Consistent enough to compound, simple enough to sustain</span></div>
      <div class="cadence-grid">
        <p><strong>Twice weekly</strong><span>Keyword blog post and channel cross-posting</span></p>
        <p><strong>Weekly</strong><span>Traffic, completed work and next-step report</span></p>
        <p><strong>Monthly</strong><span>Website pages, project photos or video and review work</span></p>
        <p><strong>Quarterly</strong><span>Seasonal email and strategy review</span></p>
      </div>
    </section>

    <footer class="report-footer">
      <p>Prepared by <a href="https://dannysullivan.ai" target="_blank" rel="noopener noreferrer">Danny Sullivan</a></p>
      <nav aria-label="Report links"><a href="/proposal/">View proposal</a><a href="/">View website</a></nav>
    </footer>
  </main>

  <style>
    :global(body) { background: var(--paper-deep); }
    .seo-report { background: var(--paper); box-shadow: var(--shadow-lift); margin: 24px auto; max-width: 1240px; }
    .report-header { align-items: center; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 24px 48px; }
    .report-brand { align-items: center; display: flex; font-family: var(--serif); font-size: 20px; gap: 9px; text-decoration: none; }
    .report-brand > span { white-space: nowrap; }
    .report-brand svg { color: var(--forest); height: 30px; width: 30px; }
    .report-brand i { color: var(--clay); font-weight: 400; }
    .report-header > div { align-items: end; display: flex; flex-direction: column; }
    .report-header > div span, .report-header > div strong { font-size: 8px; letter-spacing: .14em; text-transform: uppercase; }
    .report-header > div span { color: var(--clay-dark); }
    .report-header > div strong { color: var(--ink-muted); font-weight: 500; margin-top: 4px; }
    .report-hero { align-items: center; display: grid; gap: 72px; grid-template-columns: 1fr 330px; padding: 64px 48px; }
    .hero-message h1 { font-size: clamp(52px, 5.5vw, 76px); }
    .hero-message > p:last-child { color: var(--ink-soft); font-size: 14px; line-height: 1.75; margin: 28px 0 0; max-width: 680px; }
    .growth-score { aspect-ratio: 1; display: grid; place-items: center; position: relative; }
    .ring { border: 1px solid var(--line); border-radius: 50%; position: absolute; }
    .ring-one { inset: 0; }
    .ring-two { border-color: rgba(201,111,74,.38); inset: 25px; }
    .ring-three { background: var(--forest); border: 0; inset: 54px; }
    .score-copy { color: var(--white); display: flex; flex-direction: column; position: relative; text-align: center; z-index: 1; }
    .score-copy strong { color: var(--clay); font-family: var(--serif); font-size: 82px; font-weight: 400; letter-spacing: -.06em; line-height: .85; }
    .score-copy span, .score-copy small { font-size: 8px; letter-spacing: .14em; text-transform: uppercase; }
    .score-copy span { color: rgba(255,253,247,.7); margin-top: 9px; }
    .score-copy small { color: rgba(255,253,247,.4); margin-top: 20px; }
    .growth-path { border-bottom: 1px solid var(--line); border-top: 1px solid var(--line); display: grid; grid-template-columns: repeat(3, 1fr); }
    .growth-path article { align-items: center; display: grid; gap: 16px; grid-template-columns: 28px 1fr auto; padding: 24px 32px; }
    .growth-path article + article { border-left: 1px solid var(--line); }
    .growth-path article > span { color: var(--ink-muted); font-size: 9px; }
    .growth-path strong { display: block; font-family: var(--serif); font-size: 20px; font-weight: 400; }
    .growth-path small { color: var(--ink-muted); display: block; font-size: 8px; letter-spacing: .08em; margin-top: 2px; text-transform: uppercase; }
    .growth-path b { color: var(--ink-muted); font-size: 8px; letter-spacing: .12em; text-transform: uppercase; }
    .growth-path .complete b { color: var(--leaf); }
    .growth-path .active { background: var(--paper-deep); }
    .growth-path .active b, .growth-path .active > span { color: var(--clay-dark); }

    .live-results { border-bottom: 1px solid var(--line); padding: 56px 48px; }
    .live-results .section-title { align-items: end; }
    .live-results .section-title h2 { font-size: 38px; margin-top: 10px; }
    .result-card-grid { border-left: 1px solid var(--line); border-top: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 32px; }
    .result-card-grid article { border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); display: flex; flex-direction: column; min-height: 220px; padding: 22px; }
    .result-card-grid article > span { color: var(--ink-muted); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
    .result-card-grid article > strong { color: var(--forest); font-family: var(--serif); font-size: 25px; font-weight: 400; line-height: 1.05; margin-top: 31px; }
    .result-card-grid article > p { color: var(--ink-soft); font-size: 12px; line-height: 1.6; margin: 15px 0 24px; }
    .result-card-grid article > small { color: var(--clay-dark); font-size: 9px; font-weight: 700; letter-spacing: .08em; margin-top: auto; text-transform: uppercase; }

    .program-tracker { background: var(--forest); color: var(--white); display: grid; gap: 70px; grid-template-columns: .68fr 1.32fr; padding: 58px 48px; }
    .program-tracker header h2 { color: var(--white); font-size: 42px; }
    .program-tracker header > p:last-child { color: rgba(255,253,247,.66); font-size: 12px; line-height: 1.65; margin: 24px 0 0; }
    .tracker-list { border-top: 1px solid var(--line-light); }
    .tracker-list article { align-items: center; border-bottom: 1px solid var(--line-light); display: grid; gap: 16px; grid-template-columns: 28px 1fr auto; min-height: 62px; }
    .tracker-list article > span { color: var(--clay); font-size: 9px; }
    .tracker-list strong { display: block; font-size: 12px; font-weight: 600; }
    .tracker-list small { color: rgba(255,253,247,.58); display: block; font-size: 10px; margin-top: 2px; }
    .tracker-list b { color: var(--clay); font-size: 9px; letter-spacing: .09em; text-transform: uppercase; }

    .report-grid { display: grid; grid-template-columns: 1.45fr .55fr; }
    .score-panel { padding: 52px 48px; }
    .section-title { align-items: baseline; display: flex; justify-content: space-between; }
    .section-title .eyebrow { margin: 0; }
    .section-title > span { color: var(--ink-muted); font-size: 9px; }
    .score-list { margin-top: 26px; }
    .score-row { align-items: center; border-top: 1px solid var(--line); display: grid; gap: 18px; grid-template-columns: 150px 1fr 28px; min-height: 45px; }
    .score-row > span { color: var(--ink-soft); font-size: 11px; }
    .score-row > strong { color: var(--forest); font-size: 11px; font-variant-numeric: tabular-nums; text-align: right; }
    .score-track { background: rgba(29,40,34,.08); height: 3px; }
    .score-track i { background: var(--clay); display: block; height: 100%; }
    .measurement-note { background: var(--forest-deep); color: var(--white); padding: 52px 38px; }
    .measurement-note > strong { display: block; font-family: var(--serif); font-size: 29px; font-weight: 400; line-height: 1.1; margin-top: 54px; }
    .measurement-note > p:last-child { color: rgba(255,253,247,.58); font-size: 11px; line-height: 1.7; margin: 24px 0 0; }
    .completed-work, .next-section, .cadence-section { border-top: 1px solid var(--line); padding: 52px 48px; }
    .completed-list { border-left: 1px solid var(--line); border-top: 1px solid var(--line); display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 28px; }
    .completed-list p { align-items: start; border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); display: grid; font-size: 10px; gap: 10px; grid-template-columns: 22px 14px 1fr; line-height: 1.5; margin: 0; min-height: 72px; padding: 16px; }
    .completed-list p span { color: var(--ink-muted); font-size: 8px; }
    .completed-list p i { color: var(--clay-dark); font-style: normal; }
    .next-list { border-top: 1px solid var(--line); margin-top: 28px; }
    .next-list article { align-items: start; display: grid; gap: 24px; grid-template-columns: 36px 1fr 170px; padding: 24px 0; }
    .next-list article + article { border-top: 1px solid var(--line); }
    .next-list article > span { color: var(--clay-dark); font-size: 9px; padding-top: 5px; }
    .next-list h2 { font-size: 27px; line-height: 1; }
    .next-list p { color: var(--ink-soft); font-size: 11px; line-height: 1.65; margin: 8px 0 0; max-width: 650px; }
    .next-list small { color: var(--ink-muted); font-size: 8px; letter-spacing: .1em; padding-top: 6px; text-align: right; text-transform: uppercase; }
    .cadence-grid { border-top: 1px solid var(--line); display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 28px; }
    .cadence-grid p { margin: 0; padding: 19px 20px 0 0; }
    .cadence-grid p + p { border-left: 1px solid var(--line); padding-left: 20px; }
    .cadence-grid strong { display: block; font-family: var(--serif); font-size: 20px; font-weight: 400; }
    .cadence-grid span { color: var(--ink-muted); display: block; font-size: 9px; line-height: 1.5; margin-top: 5px; }
    .report-footer { align-items: center; background: var(--forest-deep); color: rgba(255,253,247,.5); display: flex; font-size: 8px; justify-content: space-between; padding: 18px 48px; }
    .report-footer p { margin: 0; }
    .report-footer a { text-underline-offset: 3px; }
    .report-footer nav { display: flex; gap: 24px; }
    @media (max-width: 760px) {
      .seo-report { box-shadow: none; margin: 0; }
      .report-header { align-items: flex-start; padding: 20px; }
      .report-brand { font-size: 16px; }
      .report-header > div { max-width: 105px; text-align: right; }
      .report-hero { gap: 42px; grid-template-columns: 1fr; padding: 56px 20px 48px; }
      .hero-message h1 { font-size: 48px; }
      .growth-score { justify-self: center; width: 260px; }
      .growth-path, .result-card-grid, .program-tracker, .report-grid, .completed-list, .cadence-grid { grid-template-columns: 1fr; }
      .growth-path article + article { border-left: 0; border-top: 1px solid var(--line); }
      .live-results, .score-panel, .completed-work, .next-section, .cadence-section { padding: 42px 20px; }
      .section-title { align-items: flex-start; flex-direction: column; gap: 8px; }
      .live-results .section-title h2 { font-size: 34px; }
      .result-card-grid article { min-height: 0; }
      .program-tracker { gap: 38px; padding: 48px 20px; }
      .tracker-list article { grid-template-columns: 28px 1fr; padding: 10px 0; }
      .tracker-list b { grid-column: 2; }
      .score-row { grid-template-columns: 120px 1fr 26px; }
      .completed-list p { min-height: 0; }
      .next-list article { grid-template-columns: 28px 1fr; }
      .next-list small { grid-column: 2; text-align: left; }
      .cadence-grid p, .cadence-grid p + p { border-left: 0; border-top: 1px solid var(--line); padding: 16px 0; }
      .report-footer { align-items: flex-start; flex-direction: column; gap: 10px; padding: 18px 20px; }
    }
    @media print {
      :global(body) { background: var(--paper); }
      .seo-report { box-shadow: none; margin: 0; max-width: none; print-color-adjust: exact; }
    }
  </style>
</BaseLayout>
