---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafMark from '../components/LeafMark.astro';

const growthSteps = [
  { number: '01', title: 'Be found', copy: 'Show up when Raleigh homeowners search for the work Garden & Art wants more of.' },
  { number: '02', title: 'Build trust', copy: 'Use real projects, expert guidance and client reviews to make the choice feel easy.' },
  { number: '03', title: 'Create inquiries', copy: 'Give every search, post and email a clear path to call, email or request a consultation.' },
  { number: '04', title: 'Learn and improve', copy: 'Measure what brings qualified leads, then invest the next month where it can matter most.' },
];

const workstreams = [
  {
    number: '01',
    title: 'Get found on Google',
    outcome: 'More visibility when local homeowners are ready to hire.',
    items: [
      ['Google Business Profile', 'Create or improve the listing customers see in Search and Maps, then keep services, photos and updates current.'],
      ['Google Search Console', 'Connect Google’s free search report so we can see which searches show the website and catch indexing problems.'],
      ['Google Analytics', 'Track contact forms, phone taps and email clicks so activity can be connected to real inquiries.'],
      ['Local search foundation', 'Maintain the sitemap, business information, search descriptions and service signals Google needs to understand the company.'],
    ],
  },
  {
    number: '02',
    title: 'Turn projects into proof',
    outcome: 'Help prospective clients picture the same transformation at their home.',
    items: [
      ['Before-and-after photography', 'Photograph selected projects from matched viewpoints and prepare polished images for the website, Google and social media.'],
      ['Service pages', 'Build focused pages around profitable searches such as landscape design, drainage, rain gardens, hardscaping and natural gardens.'],
      ['Project stories', 'Explain the client’s problem, Norman’s approach and the finished result instead of showing an unexplained photo gallery.'],
      ['Helpful local guides', 'Answer Raleigh homeowner questions about clay soil, shade, native plants, drainage, project costs and seasonal care.'],
    ],
  },
  {
    number: '03',
    title: 'Strengthen reputation',
    outcome: 'Make twenty years of experience visible before the first conversation.',
    items: [
      ['Review system', 'Create a direct Google review link and a comfortable request message, monitor new reviews and prepare thoughtful responses.'],
      ['Business listing consistency', 'Correct conflicting contact details across important profiles so customers and search engines see one reliable business.'],
      ['Credentials and experience', 'Feature Norman’s horticultural background, botanical-garden experience, license and specialist training where they support a decision.'],
      ['Trust-building details', 'Clarify the process, service area, response expectations and project fit so strong prospects know what happens next.'],
    ],
  },
  {
    number: '04',
    title: 'Stay visible without duplicating work',
    outcome: 'Get more value from each project photo and useful idea.',
    items: [
      ['Google updates', 'Publish useful project or seasonal updates up to twice per month when the available material supports them.'],
      ['Instagram and Facebook', 'Adapt the strongest Google update, project story or photo for both channels rather than running separate campaigns.'],
      ['Mailing list', 'Set up an opt-in list and simple branded template, then use an occasional seasonal email to encourage repeat work and referrals.'],
      ['One source, several uses', 'A single photographed project can become a website case study, Google update, social post, review request and email feature.'],
    ],
  },
];

const keywordGroups = [
  { title: 'Landscape design', search: '“landscape design Raleigh NC”', reason: 'Best match for Norman’s horticultural and design expertise.' },
  { title: 'Drainage & rain gardens', search: '“yard drainage solutions Raleigh NC”', reason: 'A common local problem with a strong specialist credential story.' },
  { title: 'Hardscaping', search: '“hardscaping Raleigh NC”', reason: 'High-value patios, walls, walkways and outdoor living projects.' },
  { title: 'Natural gardens', search: '“native plant landscaping Raleigh NC”', reason: 'A plant-focused position that separates Garden & Art from lawn-only companies.' },
];

const roadmap = [
  {
    month: 'Month 01',
    title: 'Connect and measure',
    copy: 'Confirm the official business details and connect Google Business Profile, Search Console and Analytics. Establish the dashboard, review link, keyword priorities and first project-photo plan.',
    result: 'A reliable foundation and a clear starting benchmark.',
  },
  {
    month: 'Month 02',
    title: 'Publish the first proof',
    copy: 'Create the highest-priority service or project page, prepare before-and-after photography, publish a Google update, reuse it on social and begin the review-request rhythm.',
    result: 'A new search entry point backed by visible project quality.',
  },
  {
    month: 'Month 03',
    title: 'Build on what works',
    copy: 'Publish the next best search asset, continue reviews and local updates, prepare a seasonal email when appropriate and use the first data to choose the next priority.',
    result: 'A repeatable growth rhythm guided by evidence instead of guesswork.',
  },
];

const ownerItems = [
  'Google Business Profile manager access—no password sharing',
  'The correct public address or service-area policy',
  'Current hours, service areas and preferred project types',
  'Confirmation of license, bonding and insurance details',
  'Access to one strong project and permission to photograph it',
  'A short list of happy clients who may be asked for a review',
];
---

<BaseLayout
  title="Local Growth Proposal | Garden & Art Landscapes"
  description="A customer-focused 90-day plan to grow Garden & Art Landscapes through local search, project proof, reviews and clear measurement."
  noindex
>
  <main class="proposal">
    <header class="proposal-header">
      <a class="proposal-brand" href="/" aria-label="Garden and Art Landscapes home">
        <LeafMark />
        <span>Garden <i>&</i> Art Landscapes</span>
      </a>
      <p>Local growth proposal <span>·</span> July 2026</p>
    </header>

    <section class="proposal-hero">
      <div class="hero-copy">
        <p class="eyebrow">The opportunity</p>
        <h1>Turn good work into<br /><em>the next good project.</em></h1>
        <p class="hero-intro">Garden & Art already has the experience, expertise and finished work. This 90-day program makes those strengths easier to find, easier to trust and easier to act on.</p>
      </div>
      <aside class="hero-outcome">
        <span>Primary outcome</span>
        <strong>More qualified local inquiries</strong>
        <p>Not more posting for its own sake. A practical system that helps the right Raleigh homeowners discover Garden & Art and feel confident getting in touch.</p>
      </aside>
    </section>

    <section class="growth-model" aria-labelledby="growth-title">
      <div class="growth-intro">
        <p class="eyebrow light">How growth happens</p>
        <h2 id="growth-title">A simple path from<br /><em>search to conversation.</em></h2>
      </div>
      <div class="growth-steps">
        {growthSteps.map((step) => (
          <article>
            <span>{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="foundation-note">
      <div>
        <p class="eyebrow">Already completed</p>
        <h2>The website groundwork is live.</h2>
      </div>
      <p>The redesigned site now has the correct search information, sharing previews, sitemap, local-business details, privacy page, spam-protected inquiry form and a private progress dashboard. The next phase is about earning visibility and turning it into measurable demand.</p>
    </section>

    <section class="included-work" aria-labelledby="included-title">
      <header class="section-lead">
        <p class="eyebrow">What is included</p>
        <h2 id="included-title">The work behind<br /><em>more customers.</em></h2>
        <p>Google is the center of the program. The work below is covered within the eight-hour monthly block and prioritized by value—not promised all at once. Photos, reviews, social and email support the same goal instead of becoming unrelated marketing chores.</p>
      </header>

      <div class="workstream-list">
        {workstreams.map((stream) => (
          <article class="workstream">
            <header>
              <span>{stream.number}</span>
              <div>
                <h3>{stream.title}</h3>
                <p>{stream.outcome}</p>
              </div>
            </header>
            <div class="workstream-items">
              {stream.items.map(([title, copy]) => (
                <div>
                  <strong>{title}</strong>
                  <p>{copy}</p>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="search-plan" aria-labelledby="search-title">
      <header>
        <p class="eyebrow light">What customers are searching for</p>
        <h2 id="search-title">Start with the work<br /><em>worth being found for.</em></h2>
        <p>The first search pages will focus on profitable, credible services—not every landscaping phrase at once. Each page will use real experience and original project photography.</p>
      </header>
      <div class="keyword-list">
        {keywordGroups.map((group, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{group.title}</h3>
            <strong>{group.search}</strong>
            <p>{group.reason}</p>
          </article>
        ))}
      </div>
      <p class="search-note">Future opportunities include irrigation, outdoor lighting, garden maintenance, sod, seasonal cleanup and a small number of evidence-rich service-area pages. Search Console data will determine which ones move forward first.</p>
    </section>

    <section class="roadmap" aria-labelledby="roadmap-title">
      <header class="section-lead compact">
        <p class="eyebrow">The first 90 days</p>
        <h2 id="roadmap-title">Foundation first.<br /><em>Then visible proof.</em></h2>
        <p>The eight-hour monthly block is deliberately focused. One strong, complete asset is more valuable than several rushed posts or thin pages.</p>
      </header>
      <div class="roadmap-list">
        {roadmap.map((phase) => (
          <article>
            <span>{phase.month}</span>
            <div>
              <h3>{phase.title}</h3>
              <p>{phase.copy}</p>
            </div>
            <strong>Result · {phase.result}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="operating-plan">
      <div class="rhythm">
        <p class="eyebrow">Recommended rhythm</p>
        <h2>Consistent enough<br />to compound.</h2>
        <div class="rhythm-list">
          <p><strong>Weekly</strong><span>Short progress and inquiry update</span></p>
          <p><strong>Every 2 weeks</strong><span>Google update when useful material is ready</span></p>
          <p><strong>Monthly</strong><span>Priority content, photography, reviews and insights</span></p>
          <p><strong>Quarterly</strong><span>Seasonal email and strategy review</span></p>
        </div>
      </div>

      <aside class="measurement">
        <p class="eyebrow light">What gets measured</p>
        <h2>Results, not activity.</h2>
        <ul>
          <li>Qualified contact-form inquiries</li>
          <li>Phone and email clicks from the website</li>
          <li>Google search visibility and website visits</li>
          <li>Google Business Profile calls and actions</li>
          <li>Review count, quality and response rhythm</li>
          <li>Pages and searches producing real leads</li>
        </ul>
        <p>A private dashboard, weekly summary and monthly review make the work visible and help decide what comes next.</p>
      </aside>
    </section>

    <section class="partnership">
      <div class="owner-needs">
        <p class="eyebrow">What I need from Norman</p>
        <h2>A few details unlock the plan.</h2>
        <ul>{ownerItems.map((item) => <li><span>○</span>{item}</li>)}</ul>
      </div>

      <aside class="investment">
        <p class="eyebrow light">Simple investment</p>
        <div class="rate"><strong>$100</strong><span>per hour</span></div>
        <div class="price-row waived"><span>Usual setup</span><strong><s>$500</s> Waived</strong></div>
        <div class="price-row"><span>Monthly time</span><strong>8 hours</strong></div>
        <div class="price-row"><span>Monthly investment</span><strong>$800</strong></div>
        <div class="total"><span>90-day investment</span><strong>$2,400</strong></div>
        <p class="payment">Preferred-client courtesy: the normal $500 setup fee is waived. Time is tracked and summarized. Any work beyond eight hours requires approval first.</p>
      </aside>
    </section>

    <section class="expectation">
      <p class="eyebrow light">What success looks like</p>
      <h2>A clearer local presence, stronger proof and a growing understanding of what brings the right clients to Garden & Art.</h2>
      <p>Search rankings cannot be guaranteed, and meaningful organic growth takes time. This program creates the assets, local signals and measurement needed to improve visibility steadily and make better decisions each month.</p>
    </section>

    <section class="next-step">
      <p class="eyebrow">Recommended next step</p>
      <h2>Confirm the official business details, Google access and first project to photograph.</h2>
    </section>

    <footer class="proposal-footer">
      <p>Prepared by <a href="https://dannysullivan.ai" target="_blank" rel="noopener noreferrer">Danny Sullivan</a></p>
      <p>Garden & Art Landscapes · Raleigh, North Carolina</p>
    </footer>
  </main>

  <style>
    :global(body) { background: var(--paper-deep); }
    .proposal { background: var(--paper); box-shadow: var(--shadow-lift); margin: 24px auto; max-width: 1240px; overflow: hidden; }
    .proposal-header { align-items: center; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 24px 48px; }
    .proposal-header > p { color: var(--ink-muted); font-size: 9px; letter-spacing: .14em; margin: 0; text-transform: uppercase; }
    .proposal-header > p span { color: var(--clay); margin: 0 5px; }
    .proposal-brand { align-items: center; display: flex; font-family: var(--serif); font-size: 20px; gap: 9px; text-decoration: none; }
    .proposal-brand > span { white-space: nowrap; }
    .proposal-brand svg { color: var(--forest); height: 30px; width: 30px; }
    .proposal-brand i { color: var(--clay); font-weight: 400; }

    .proposal-hero { align-items: end; display: grid; gap: 80px; grid-template-columns: 1.4fr .6fr; padding: 80px 48px 72px; }
    .proposal-hero h1 { font-size: clamp(58px, 6.2vw, 88px); }
    .hero-intro { color: var(--ink-soft); font-size: 15px; line-height: 1.75; margin: 30px 0 0; max-width: 690px; }
    .hero-outcome { border-left: 1px solid var(--line); padding: 8px 0 5px 28px; }
    .hero-outcome > span { color: var(--clay-dark); display: block; font-size: 9px; font-weight: 700; letter-spacing: .16em; margin-bottom: 16px; text-transform: uppercase; }
    .hero-outcome strong { color: var(--forest); display: block; font-family: var(--serif); font-size: 30px; font-weight: 400; letter-spacing: -.025em; line-height: 1.04; }
    .hero-outcome p { color: var(--ink-soft); font-size: 11px; line-height: 1.65; margin: 18px 0 0; }

    .growth-model { background: var(--forest-deep); color: var(--white); display: grid; gap: 64px; grid-template-columns: .72fr 1.28fr; padding: 56px 48px; }
    .growth-intro h2 { color: var(--white); font-size: 45px; }
    .growth-steps { border-left: 1px solid var(--line-light); border-top: 1px solid var(--line-light); display: grid; grid-template-columns: 1fr 1fr; }
    .growth-steps article { border-bottom: 1px solid var(--line-light); border-right: 1px solid var(--line-light); padding: 20px 22px 24px; }
    .growth-steps article > span { color: var(--clay); font-size: 8px; letter-spacing: .12em; }
    .growth-steps h3 { color: var(--white); font-family: var(--serif); font-size: 22px; font-weight: 400; margin: 19px 0 7px; }
    .growth-steps p { color: rgba(255,253,247,.58); font-size: 10px; line-height: 1.55; margin: 0; }

    .foundation-note { align-items: center; border-bottom: 1px solid var(--line); display: grid; gap: 64px; grid-template-columns: .8fr 1.2fr; padding: 42px 48px; }
    .foundation-note .eyebrow { margin-bottom: 8px; }
    .foundation-note h2 { font-size: 31px; }
    .foundation-note > p { color: var(--ink-soft); font-size: 12px; line-height: 1.7; margin: 0; }

    .included-work { padding: 80px 48px; }
    .section-lead { align-items: end; display: grid; gap: 36px; grid-template-columns: .45fr 1fr .7fr; margin-bottom: 48px; }
    .section-lead .eyebrow { margin: 0; }
    .section-lead h2 { font-size: 47px; }
    .section-lead > p:last-child { color: var(--ink-soft); font-size: 11px; line-height: 1.65; margin: 0; }
    .workstream-list { border-top: 1px solid var(--line); }
    .workstream { border-bottom: 1px solid var(--line); display: grid; gap: 42px; grid-template-columns: .62fr 1.38fr; padding: 38px 0; }
    .workstream > header { display: grid; gap: 20px; grid-template-columns: 30px 1fr; }
    .workstream > header > span { color: var(--clay-dark); font-size: 9px; letter-spacing: .12em; padding-top: 7px; }
    .workstream h3 { color: var(--forest); font-family: var(--serif); font-size: 30px; font-weight: 400; letter-spacing: -.025em; line-height: 1; margin: 0 0 12px; }
    .workstream header p { color: var(--clay-dark); font-size: 10px; font-weight: 700; line-height: 1.55; margin: 0; max-width: 310px; }
    .workstream-items { display: grid; gap: 22px 28px; grid-template-columns: 1fr 1fr; }
    .workstream-items strong { color: var(--ink); display: block; font-size: 10px; letter-spacing: .04em; margin-bottom: 5px; }
    .workstream-items p { color: var(--ink-soft); font-size: 10px; line-height: 1.6; margin: 0; }

    .search-plan { background: var(--clay); color: var(--white); display: grid; gap: 42px 64px; grid-template-columns: .7fr 1.3fr; padding: 68px 48px; }
    .search-plan > header h2 { color: var(--white); font-size: 48px; }
    .search-plan > header h2 em { color: var(--forest-deep); }
    .search-plan > header > p:last-child { color: rgba(255,253,247,.75); font-size: 11px; line-height: 1.65; margin: 25px 0 0; }
    .keyword-list { border-top: 1px solid rgba(255,253,247,.28); }
    .keyword-list article { align-items: start; border-bottom: 1px solid rgba(255,253,247,.28); display: grid; gap: 16px; grid-template-columns: 28px 1fr 1.15fr; padding: 18px 0; }
    .keyword-list article > span { color: var(--forest-deep); font-size: 8px; font-weight: 700; padding-top: 3px; }
    .keyword-list h3 { font-family: var(--serif); font-size: 18px; font-weight: 400; line-height: 1.15; margin: 0; }
    .keyword-list strong { font-size: 10px; font-weight: 700; line-height: 1.5; }
    .keyword-list p { color: rgba(255,253,247,.72); font-size: 9px; grid-column: 3; line-height: 1.5; margin: -8px 0 0; }
    .search-note { border-left: 1px solid rgba(255,253,247,.32); color: rgba(255,253,247,.7); font-size: 9px; grid-column: 2; line-height: 1.6; margin: -18px 0 0; padding-left: 18px; }

    .roadmap { padding: 78px 48px; }
    .section-lead.compact { grid-template-columns: .45fr 1fr .7fr; }
    .roadmap-list { border-top: 1px solid var(--line); }
    .roadmap-list article { align-items: start; border-bottom: 1px solid var(--line); display: grid; gap: 30px; grid-template-columns: 100px 1fr .55fr; padding: 28px 0; }
    .roadmap-list article > span { color: var(--clay-dark); font-size: 9px; font-weight: 700; letter-spacing: .12em; padding-top: 5px; text-transform: uppercase; }
    .roadmap-list h3 { color: var(--forest); font-family: var(--serif); font-size: 25px; font-weight: 400; margin: 0 0 8px; }
    .roadmap-list p { color: var(--ink-soft); font-size: 10px; line-height: 1.6; margin: 0; }
    .roadmap-list article > strong { border-left: 1px solid var(--line); color: var(--clay-dark); font-size: 9px; line-height: 1.6; padding-left: 20px; }

    .operating-plan { display: grid; grid-template-columns: 1fr 1fr; }
    .rhythm { background: var(--paper-deep); padding: 56px 48px; }
    .rhythm h2, .measurement h2 { font-size: 39px; }
    .rhythm-list { border-top: 1px solid var(--line); margin-top: 30px; }
    .rhythm-list p { border-bottom: 1px solid var(--line); display: grid; font-size: 10px; grid-template-columns: 125px 1fr; margin: 0; padding: 13px 0; }
    .rhythm-list strong { color: var(--clay-dark); }
    .rhythm-list span { color: var(--ink-soft); }
    .measurement { background: var(--forest); color: var(--white); padding: 56px 48px; }
    .measurement h2 { color: var(--white); }
    .measurement ul { list-style: none; margin: 27px 0 22px; padding: 0; }
    .measurement li { border-top: 1px solid var(--line-light); color: rgba(255,253,247,.78); font-size: 10px; padding: 9px 0; }
    .measurement > p:last-child { color: rgba(255,253,247,.52); font-size: 9px; line-height: 1.6; margin: 0; }

    .partnership { display: grid; grid-template-columns: 1.35fr .65fr; padding: 72px 48px; }
    .owner-needs { padding-right: 72px; }
    .owner-needs h2 { font-size: 41px; }
    .owner-needs ul { display: grid; gap: 0 28px; grid-template-columns: 1fr 1fr; list-style: none; margin: 29px 0 0; padding: 0; }
    .owner-needs li { border-top: 1px solid var(--line); color: var(--ink-soft); display: grid; font-size: 10px; gap: 9px; grid-template-columns: 14px 1fr; line-height: 1.5; padding: 11px 0; }
    .owner-needs li span { color: var(--clay); }
    .investment { background: var(--forest-deep); color: var(--white); padding: 30px; }
    .rate { align-items: baseline; display: flex; gap: 9px; margin: -2px 0 18px; }
    .rate strong { color: var(--clay); font-family: var(--serif); font-size: 49px; font-weight: 400; letter-spacing: -.04em; }
    .rate span { color: rgba(255,253,247,.55); font-size: 9px; letter-spacing: .1em; text-transform: uppercase; }
    .price-row { border-top: 1px solid var(--line-light); display: flex; font-size: 10px; justify-content: space-between; padding: 10px 0; }
    .price-row span { color: rgba(255,253,247,.6); }
    .price-row strong { font-weight: 600; }
    .price-row.waived strong { color: var(--clay); }
    .price-row.waived s { color: rgba(255,253,247,.42); font-weight: 400; margin-right: 5px; }
    .total { align-items: end; border-top: 1px solid var(--line-light); display: flex; justify-content: space-between; padding-top: 14px; }
    .total span { color: rgba(255,253,247,.58); font-size: 8px; letter-spacing: .1em; text-transform: uppercase; }
    .total strong { font-family: var(--serif); font-size: 28px; font-weight: 400; }
    .payment { color: rgba(255,253,247,.46); font-size: 8px; line-height: 1.6; margin: 14px 0 0; }

    .expectation { background: var(--forest-deep); color: var(--white); padding: 66px 48px; }
    .expectation h2 { color: var(--white); font-size: clamp(38px, 4.1vw, 58px); max-width: 1040px; }
    .expectation > p:last-child { color: rgba(255,253,247,.58); font-size: 10px; line-height: 1.65; margin: 25px 0 0; max-width: 700px; }
    .next-step { background: var(--clay); color: var(--white); display: grid; gap: 40px; grid-template-columns: .35fr 1.65fr; padding: 34px 48px; }
    .next-step .eyebrow { color: rgba(255,253,247,.75); margin: 6px 0 0; }
    .next-step h2 { color: var(--white); font-size: 29px; line-height: 1.05; }
    .proposal-footer { align-items: center; background: var(--paper); color: var(--ink-muted); display: flex; font-size: 8px; justify-content: space-between; letter-spacing: .04em; padding: 18px 48px; }
    .proposal-footer p { margin: 0; }
    .proposal-footer a { text-underline-offset: 3px; }

    @media (max-width: 760px) {
      .proposal { box-shadow: none; margin: 0; }
      .proposal-header { align-items: flex-start; gap: 16px; padding: 20px; }
      .proposal-header > p { line-height: 1.5; max-width: 112px; text-align: right; }
      .proposal-header > p span { display: none; }
      .proposal-brand { font-size: 16px; }
      .proposal-brand svg { height: 27px; width: 27px; }
      .proposal-hero { gap: 38px; grid-template-columns: 1fr; padding: 62px 20px 52px; }
      .proposal-hero h1 { font-size: clamp(48px, 13vw, 62px); }
      .hero-outcome { padding-left: 20px; }
      .growth-model { gap: 36px; grid-template-columns: 1fr; padding: 50px 20px; }
      .growth-intro h2 { font-size: 38px; }
      .growth-steps { grid-template-columns: 1fr; }
      .foundation-note { gap: 20px; grid-template-columns: 1fr; padding: 38px 20px; }
      .included-work, .roadmap { padding: 58px 20px; }
      .section-lead, .section-lead.compact { align-items: start; gap: 16px; grid-template-columns: 1fr; margin-bottom: 36px; }
      .section-lead h2 { font-size: 41px; }
      .workstream { gap: 28px; grid-template-columns: 1fr; padding: 34px 0; }
      .workstream-items { grid-template-columns: 1fr; }
