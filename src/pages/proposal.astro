---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeafMark from '../components/LeafMark.astro';

const growthSteps = [
  { number: '01', title: 'Be found', copy: 'Show up when Raleigh homeowners search for the work Garden & Art wants more of.' },
  { number: '02', title: 'Build trust', copy: 'Use real projects, expert guidance and client reviews to make the choice feel easy.' },
  { number: '03', title: 'Create inquiries', copy: 'Give every search, post and email a clear path to call, email or request a consultation.' },
  { number: '04', title: 'Do more of what works', copy: 'See which pages and posts lead to calls, then spend the next month on the work bringing the best prospects.' },
];

const headlineDeliverables = [
  { amount: '8', label: 'new website pages', copy: 'Built during the first 90 days around the services Garden & Art most wants to sell.' },
  { amount: '2+', label: 'blog posts each week', copy: 'Based on the Raleigh keyword plan and published consistently—not only when there is spare time.' },
  { amount: '3', label: 'places for every strong idea', copy: 'Each useful article is adapted for Facebook, Instagram and the Google Business Profile.' },
  { amount: '1', label: 'email and review system', copy: 'Contacts organized, signup connected, branded email ready and past-customer review outreach sent.' },
  { amount: '1', label: 'photo or video package', copy: 'A project captured by Danny with matched before-and-after views and short video when it helps tell the story.' },
  { amount: '1', label: 'live results dashboard', copy: 'Website traffic, Google searches, leads, published work and next steps in one place.' },
  { amount: '1', label: 'clear report each week', copy: 'What was completed, whether traffic is growing, what customers responded to and what comes next.' },
];

const workstreams = [
  {
    number: '01',
    title: 'Build eight new website pages',
    outcome: 'Give each important service its own clear way to be found and understood.',
    items: [
      ['Four priority service pages', 'Landscape Design, Drainage & Rain Gardens, Hardscaping, and Native & Natural Garden Design—each written for Raleigh homeowners.'],
      ['Two supporting service pages', 'Outdoor Lighting & Irrigation, plus Garden Care & Maintenance, using Norman’s actual services and project experience.'],
      ['About Norman', 'A dedicated page for his horticultural training, botanical-garden experience, design point of view and credentials.'],
      ['Projects & Before/After', 'A project hub that turns the photo library into proof, with room to add individual project stories over time.'],
    ],
  },
  {
    number: '02',
    title: 'Publish at least two blog posts a week',
    outcome: 'Create more chances for Raleigh homeowners to discover the business every week.',
    items: [
      ['Keyword-based topics', 'Use the completed Raleigh research to answer questions about design costs, clay soil, shade, native plants, drainage, rain gardens and seasonal care.'],
      ['Minimum weekly output', 'Publish two useful posts every week—about eight or nine each month—with a clear link back to a relevant service.'],
      ['Post every strong idea in three places', 'Adapt each article for Facebook, Instagram and the Google Business Profile. Two weekly articles can become up to six useful social posts.'],
      ['Monthly content calendar', 'Plan the next four weeks in advance so posts support the season, current projects and the services Garden & Art wants to book.'],
    ],
  },
  {
    number: '03',
    title: 'Build and maintain the Google Business Profile',
    outcome: 'Make the business easier to find, evaluate and contact directly from Google Maps.',
    items: [
      ['Complete profile setup', 'Add the correct business name, service area, hours, phone, website, categories, services and description.'],
      ['Project photos', 'Add strong finished work and before-and-after images so the profile shows what Garden & Art actually does.'],
      ['Regular Google posts', 'Reuse the weekly blog and project content on the profile so it stays current instead of looking abandoned.'],
      ['Ongoing upkeep', 'Watch for questions, incorrect edits, new reviews and missing information, then keep the profile accurate.'],
    ],
  },
  {
    number: '04',
    title: 'Create the email list and review campaign',
    outcome: 'Turn past relationships into reviews, repeat work and referrals.',
    items: [
      ['Set up the email platform', 'Create the account, branded template, unsubscribe settings and basic list structure.'],
      ['Bring in current contacts', 'Clean and import eligible customer contacts supplied by Norman, while keeping opt-out and permission requirements in place.'],
      ['Add website signup', 'Connect a simple email signup to the website so interested homeowners can join the list.'],
      ['Ask past customers for reviews', 'Danny will write and send the review request email, link directly to Google and track which follow-up is needed.'],
    ],
  },
  {
    number: '05',
    title: 'Create before-and-after photography and video',
    outcome: 'Show the difference Garden & Art makes instead of asking prospects to imagine it.',
    items: [
      ['Matched before-and-after views', 'Danny will photograph projects from the same position so the change is immediate and convincing.'],
      ['Short project video', 'Capture simple walkthroughs, details or Norman explaining the work when motion and voice tell the story better than still photos.'],
      ['One shoot, many uses', 'Prepare each strong project for the website, blog, Google profile, Instagram, Facebook, email and review follow-up.'],
      ['Organized photo library', 'Name and sort the best images by project, service and location so content can be created quickly.'],
    ],
  },
  {
    number: '06',
    title: 'Build the results dashboard and weekly report',
    outcome: 'Let Norman see the work, traffic and customer response without learning marketing software.',
    items: [
      ['Google Analytics', 'Connect website tracking to show visits, popular pages, contact forms, phone taps and email clicks.'],
      ['Google Search Console', 'Connect Google’s search report to show the searches people use, which pages appear and whether visibility is increasing.'],
      ['One client dashboard', 'Bring traffic, searches, leads, reviews, published pages, weekly posts and upcoming work into one easy view.'],
      ['Weekly plain-English report', 'Send a short summary of what was completed, what changed, what brought interest and what is planned next.'],
    ],
  },
];

const keywordGroups = [
  { title: 'Landscape design', search: '“landscape design Raleigh NC”', reason: 'Best match for Norman’s horticultural and design expertise.' },
  { title: 'Drainage & rain gardens', search: '“yard drainage solutions Raleigh NC”', reason: 'A common local problem with a strong specialist credential story.' },
  { title: 'Hardscaping', search: '“hardscaping Raleigh NC”', reason: 'High-value patios, walls, walkways and outdoor living projects.' },
  { title: 'Natural gardens', search: '“native plant landscaping Raleigh NC”', reason: 'A plant-focused position that separates Garden & Art from lawn-only companies.' },
];

const roadmap = [
  {
    month: 'Month 01',
    title: 'Build the system',
    copy: 'Build the Google Business Profile, connect Analytics and Search Console, create the client dashboard, set up the email list and website signup, organize customer contacts and begin the two-posts-a-week schedule.',
    result: 'Everything connected, visible and ready to grow.',
  },
  {
    month: 'Month 02',
    title: 'Expand the website and proof',
    copy: 'Publish the first four new pages, continue at least two blog posts a week, cross-post them, photograph or film a strong project and send the past-customer review email.',
    result: 'More ways to be found, stronger proof and new reviews arriving.',
  },
  {
    month: 'Month 03',
    title: 'Finish the launch and improve it',
    copy: 'Publish the remaining four pages, continue the weekly blog and cross-posting schedule, add another photo or video story and use dashboard results to choose the next topics and improvements.',
    result: 'A complete local marketing system with a clear ongoing rhythm.',
  },
];

const ownerItems = [
  'Google Business Profile manager access—no password sharing',
  'The correct public address or service-area policy',
  'Current hours, service areas and preferred project types',
  'Confirmation of license, bonding and insurance details',
  'Access to strong projects and permission to photograph or film them',
  'An export of eligible past and current customer contacts',
  'A short list of happy clients who may be asked for a review',
];
---

<BaseLayout
  title="Local Growth Proposal | Garden & Art Landscapes"
  description="A customer-focused 90-day plan to grow Garden & Art Landscapes through local search, project proof, reviews and clear measurement."
  noindex
>
  <main class="proposal">
    <header class="proposal-header">
      <a class="proposal-brand" href="/" aria-label="Garden and Art Landscapes home">
        <LeafMark />
        <span>Garden <i>&</i> Art Landscapes</span>
      </a>
      <p>Local growth proposal <span>·</span> July 2026</p>
    </header>

    <section class="proposal-hero">
      <div class="hero-copy">
        <p class="eyebrow">The goal</p>
        <h1>Turn good work into<br /><em>the next good project.</em></h1>
        <p class="hero-intro">Garden & Art already has the experience and finished work. This 90-day plan helps more Raleigh homeowners find it, trust it and get in touch.</p>
      </div>
      <aside class="hero-outcome">
        <span>What we are working toward</span>
        <strong>More calls from the right local homeowners</strong>
        <p>The point is not to stay busy online. It is to show the right work to people who are looking for it and give them a clear reason to call.</p>
      </aside>
    </section>

    <section class="growth-model" aria-labelledby="growth-title">
      <div class="growth-intro">
        <p class="eyebrow light">How growth happens</p>
        <h2 id="growth-title">How the work leads<br /><em>to new customers.</em></h2>
      </div>
      <div class="growth-steps">
        {growthSteps.map((step) => (
          <article>
            <span>{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="foundation-note">
      <div>
        <p class="eyebrow">Already completed</p>
        <h2>The website groundwork is live.</h2>
      </div>
      <p>The redesigned site is live, works on phones, shares correctly, gives Google clear business information and includes a privacy page, spam-protected contact form and progress dashboard. The next step is adding the pages, posts, reviews and tracking that bring more people to it.</p>
    </section>

    <section class="monthly-output" aria-labelledby="output-title">
      <header>
        <p class="eyebrow light">The concrete deliverables</p>
        <h2 id="output-title">What gets built,<br /><em>published and measured.</em></h2>
        <p>The first 90 days build the system and expand the website. Every week adds useful content, and the dashboard shows whether more people are finding and contacting Garden & Art.</p>
      </header>
      <div class="output-list">
        {headlineDeliverables.map((item) => (
          <article>
            <strong>{item.amount}</strong>
            <div><h3>{item.label}</h3><p>{item.copy}</p></div>
          </article>
        ))}
      </div>
      <p class="output-note">Two original blog posts each week can also become Facebook, Instagram and Google Business updates—up to 24 useful posts across those channels each month.</p>
    </section>

    <section class="included-work" aria-labelledby="included-title">
      <header class="section-lead">
        <p class="eyebrow">What is included</p>
        <h2 id="included-title">The work behind<br /><em>more customers.</em></h2>
        <p>Google is the center of the plan. The work below fits inside the eight-hour monthly block and is handled in priority order—not all at once. Photos, reviews, social posts and email all help bring people back to the same strong website.</p>
      </header>

      <div class="workstream-list">
        {workstreams.map((stream) => (
          <article class="workstream">
            <header>
              <span>{stream.number}</span>
              <div>
                <h3>{stream.title}</h3>
                <p>{stream.outcome}</p>
              </div>
            </header>
            <div class="workstream-items">
              {stream.items.map(([title, copy]) => (
                <div>
                  <strong>{title}</strong>
                  <p>{copy}</p>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="search-plan" aria-labelledby="search-title">
      <header>
        <p class="eyebrow light">What customers are searching for</p>
        <h2 id="search-title">Start with the work<br /><em>worth being found for.</em></h2>
        <p>The first pages will focus on the services Garden & Art most wants to sell—not every landscaping phrase at once. Each page will use Norman’s real experience and original project photography.</p>
      </header>
      <div class="keyword-list">
        {keywordGroups.map((group, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{group.title}</h3>
            <strong>{group.search}</strong>
            <p>{group.reason}</p>
          </article>
        ))}
      </div>
      <p class="search-note">Later pages may cover irrigation, outdoor lighting, garden maintenance, sod and seasonal cleanup. Google’s search report will show which topics people are actually looking for and help choose what comes next.</p>
    </section>

    <section class="roadmap" aria-labelledby="roadmap-title">
      <header class="section-lead compact">
        <p class="eyebrow">The first 90 days</p>
        <h2 id="roadmap-title">Foundation first.<br /><em>Then visible proof.</em></h2>
        <p>The eight-hour monthly block stays focused. Short weekly posts keep the business visible; one larger page or project story builds long-term value.</p>
      </header>
      <div class="roadmap-list">
        {roadmap.map((phase) => (
          <article>
            <span>{phase.month}</span>
            <div>
              <h3>{phase.title}</h3>
              <p>{phase.copy}</p>
            </div>
            <strong>Result · {phase.result}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="operating-plan">
      <div class="rhythm">
        <p class="eyebrow">Recommended rhythm</p>
        <h2>A steady, useful<br />weekly presence.</h2>
        <div class="rhythm-list">
          <p><strong>Twice a week</strong><span>A useful project, seasonal or homeowner post</span></p>
          <p><strong>Weekly</strong><span>A short note showing what was completed</span></p>
          <p><strong>Monthly</strong><span>A larger page or story, photography, reviews and results report</span></p>
          <p><strong>Quarterly</strong><span>A seasonal customer email and plan review</span></p>
        </div>
      </div>

      <aside class="measurement">
        <p class="eyebrow light">Built into the client dashboard</p>
        <h2>One place to see growth.</h2>
        <ul>
          <li>Website visits and whether traffic is increasing</li>
          <li>Google searches bringing people to the site</li>
          <li>Contact forms, phone taps and email clicks</li>
          <li>Google Business Profile views, calls and actions</li>
          <li>New pages, blog posts, social posts and emails completed</li>
          <li>Reviews received and next week’s action list</li>
        </ul>
        <p>Google Analytics and Search Console feed the dashboard. Norman gets a short weekly report explaining the numbers in plain language and showing exactly what was completed.</p>
      </aside>
    </section>

    <section class="partnership">
      <div class="owner-needs">
        <p class="eyebrow">What I need from Norman</p>
        <h2>A few details unlock the plan.</h2>
        <ul>{ownerItems.map((item) => <li><span>○</span>{item}</li>)}</ul>
      </div>

      <aside class="investment">
        <p class="eyebrow light">Simple investment</p>
        <div class="rate"><strong>$100</strong><span>per hour</span></div>
        <div class="price-row waived"><span>Usual setup</span><strong><s>$500</s> Waived</strong></div>
        <div class="price-row"><span>Monthly time</span><strong>8 hours</strong></div>
        <div class="price-row"><span>Monthly investment</span><strong>$800</strong></div>
        <div class="total"><span>90-day investment</span><strong>$2,400</strong></div>
        <p class="payment">Preferred-client courtesy: the normal $500 setup fee is waived. Time is tracked and summarized. Any work beyond eight hours requires approval first. The program is reviewed together at 90 days before continuing.</p>
      </aside>
    </section>

    <section class="expectation">
      <p class="eyebrow light">What success looks like</p>
      <h2>A clearer local presence, stronger proof and a growing understanding of what brings the right clients to Garden & Art.</h2>
      <p>No one can promise a Google ranking, and search growth takes time. This plan steadily adds the pages, photos, reviews and useful posts that give Garden & Art more chances to be found and chosen.</p>
    </section>

    <section class="next-step">
      <p class="eyebrow">Recommended next step</p>
      <h2>Confirm the official business details, Google access and first project to photograph.</h2>
    </section>

    <footer class="proposal-footer">
      <p>Prepared by <a href="https://dannysullivan.ai" target="_blank" rel="noopener noreferrer">Danny Sullivan</a></p>
      <p>Garden & Art Landscapes · Raleigh, North Carolina</p>
    </footer>
  </main>

  <style>
    :global(body) { background: var(--paper-deep); }
    .proposal { background: var(--paper); box-shadow: var(--shadow-lift); margin: 24px auto; max-width: 1240px; overflow: hidden; }
    .proposal-header { align-items: center; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 24px 48px; }
    .proposal-header > p { color: var(--ink-muted); font-size: 10px; letter-spacing: .14em; margin: 0; text-transform: uppercase; }
    .proposal-header > p span { color: var(--clay); margin: 0 5px; }
    .proposal-brand { align-items: center; display: flex; font-family: var(--serif); font-size: 20px; gap: 9px; text-decoration: none; }
    .proposal-brand > span { white-space: nowrap; }
    .proposal-brand svg { color: var(--forest); height: 30px; width: 30px; }
    .proposal-brand i { color: var(--clay); font-weight: 400; }

    .proposal-hero { align-items: end; display: grid; gap: 80px; grid-template-columns: 1.4fr .6fr; padding: 80px 48px 72px; }
    .proposal-hero h1 { font-size: clamp(58px, 6.2vw, 88px); }
    .hero-intro { color: var(--ink-soft); font-size: 15px; line-height: 1.75; margin: 30px 0 0; max-width: 690px; }
    .hero-outcome { border-left: 1px solid var(--line); padding: 8px 0 5px 28px; }
    .hero-outcome > span { color: var(--clay-dark); display: block; font-size: 10px; font-weight: 700; letter-spacing: .16em; margin-bottom: 16px; text-transform: uppercase; }
    .hero-outcome strong { color: var(--forest); display: block; font-family: var(--serif); font-size: 30px; font-weight: 400; letter-spacing: -.025em; line-height: 1.04; }
    .hero-outcome p { color: var(--ink-soft); font-size: 13px; line-height: 1.65; margin: 18px 0 0; }

    .growth-model { background: var(--forest-deep); color: var(--white); display: grid; gap: 64px; grid-template-columns: .72fr 1.28fr; padding: 56px 48px; }
    .growth-intro h2 { color: var(--white); font-size: 45px; }
    .growth-steps { border-left: 1px solid var(--line-light); border-top: 1px solid var(--line-light); display: grid; grid-template-columns: 1fr 1fr; }
    .growth-steps article { border-bottom: 1px solid var(--line-light); border-right: 1px solid var(--line-light); padding: 20px 22px 24px; }
    .growth-steps article > span { color: var(--clay); font-size: 9px; letter-spacing: .12em; }
    .growth-steps h3 { color: var(--white); font-family: var(--serif); font-size: 22px; font-weight: 400; margin: 19px 0 7px; }
    .growth-steps p { color: rgba(255,253,247,.68); font-size: 12px; line-height: 1.6; margin: 0; }

    .foundation-note { align-items: center; border-bottom: 1px solid var(--line); display: grid; gap: 64px; grid-template-columns: .8fr 1.2fr; padding: 42px 48px; }
    .foundation-note .eyebrow { margin-bottom: 8px; }
    .foundation-note h2 { font-size: 31px; }
    .foundation-note > p { color: var(--ink-soft); font-size: 14px; line-height: 1.7; margin: 0; }

    .monthly-output { background: var(--forest); color: var(--white); display: grid; gap: 48px 64px; grid-template-columns: .72fr 1.28fr; padding: 66px 48px; }
    .monthly-output > header h2 { color: var(--white); font-size: 48px; }
    .monthly-output > header > p:last-child { color: rgba(255,253,247,.68); font-size: 13px; line-height: 1.65; margin: 25px 0 0; }
    .output-list { border-top: 1px solid var(--line-light); }
    .output-list article { align-items: start; border-bottom: 1px solid var(--line-light); display: grid; gap: 18px; grid-template-columns: 48px 1fr; padding: 17px 0; }
    .output-list article > strong { color: var(--clay); font-family: var(--serif); font-size: 34px; font-weight: 400; line-height: 1; }
    .output-list h3 { color: var(--white); font-family: var(--serif); font-size: 21px; font-weight: 400; line-height: 1.05; margin: 0 0 6px; }
    .output-list p { color: rgba(255,253,247,.68); font-size: 12px; line-height: 1.55; margin: 0; }
    .output-note { border-left: 1px solid var(--clay); color: rgba(255,253,247,.72); font-size: 12px; grid-column: 2; line-height: 1.6; margin: -20px 0 0; padding-left: 18px; }

    .included-work { padding: 80px 48px; }
    .section-lead { align-items: end; display: grid; gap: 36px; grid-template-columns: .45fr 1fr .7fr; margin-bottom: 48px; }
    .section-lead .eyebrow { margin: 0; }
    .section-lead h2 { font-size: 47px; }
    .section-lead > p:last-child { color: var(--ink-soft); font-size: 13px; line-height: 1.65; margin: 0; }
    .workstream-list { border-top: 1px solid var(--line); }
    .workstream { border-bottom: 1px solid var(--line); display: grid; gap: 42px; grid-template-columns: .62fr 1.38fr; padding: 38px 0; }
    .workstream > header { display: grid; gap: 20px; grid-template-columns: 30px 1fr; }
    .workstream > header > span { color: var(--clay-dark); font-size: 10px; letter-spacing: .12em; padding-top: 7px; }
    .workstream h3 { color: var(--forest); font-family: var(--serif); font-size: 30px; font-weight: 400; letter-spacing: -.025em; line-height: 1; margin: 0 0 12px; }
    .workstream header p { color: var(--clay-dark); font-size: 12px; font-weight: 700; line-height: 1.55; margin: 0; max-width: 330px; }
    .workstream-items { display: grid; gap: 22px 28px; grid-template-columns: 1fr 1fr; }
    .workstream-items strong { color: var(--ink); display: block; font-size: 12px; letter-spacing: .02em; margin-bottom: 5px; }
    .workstream-items p { color: var(--ink-soft); font-size: 12px; line-height: 1.65; margin: 0; }

    .search-plan { background: var(--clay); color: var(--white); display: grid; gap: 42px 64px; grid-template-columns: .7fr 1.3fr; padding: 68px 48px; }
    .search-plan > header h2 { color: var(--white); font-size: 48px; }
    .search-plan > header h2 em { color: var(--forest-deep); }
    .search-plan > header > p:last-child { color: rgba(255,253,247,.82); font-size: 13px; line-height: 1.65; margin: 25px 0 0; }
    .keyword-list { border-top: 1px solid rgba(255,253,247,.28); }
    .keyword-list article { align-items: start; border-bottom: 1px solid rgba(255,253,247,.28); display: grid; gap: 16px; grid-template-columns: 28px 1fr 1.15fr; padding: 18px 0; }
    .keyword-list article > span { color: var(--forest-deep); font-size: 9px; font-weight: 700; padding-top: 3px; }
    .keyword-list h3 { font-family: var(--serif); font-size: 18px; font-weight: 400; line-height: 1.15; margin: 0; }
    .keyword-list strong { font-size: 12px; font-weight: 700; line-height: 1.5; }
    .keyword-list p { color: rgba(255,253,247,.8); font-size: 12px; grid-column: 3; line-height: 1.55; margin: -8px 0 0; }
    .search-note { border-left: 1px solid rgba(255,253,247,.4); color: rgba(255,253,247,.8); font-size: 12px; grid-column: 2; line-height: 1.65; margin: -18px 0 0; padding-left: 18px; }

    .roadmap { padding: 78px 48px; }
    .section-lead.compact { grid-template-columns: .45fr 1fr .7fr; }
    .roadmap-list { border-top: 1px solid var(--line); }
    .roadmap-list article { align-items: start; border-bottom: 1px solid var(--line); display: grid; gap: 30px; grid-template-columns: 100px 1fr .55fr; padding: 28px 0; }
    .roadmap-list article > span { color: var(--clay-dark); font-size: 10px; font-weight: 700; letter-spacing: .12em; padding-top: 5px; text-transform: uppercase; }
    .roadmap-list h3 { color: var(--forest); font-family: var(--serif); font-size: 25px; font-weight: 400; margin: 0 0 8px; }
    .roadmap-list p { color: var(--ink-soft); font-size: 12px; line-height: 1.65; margin: 0; }
    .roadmap-list article > strong { border-left: 1px solid var(--line); color: var(--clay-dark); font-size: 12px; line-height: 1.6; padding-left: 20px; }

    .operating-plan { display: grid; grid-template-columns: 1fr 1fr; }
    .rhythm { background: var(--paper-deep); padding: 56px 48px; }
    .rhythm h2, .measurement h2 { font-size: 39px; }
    .rhythm-list { border-top: 1px solid var(--line); margin-top: 30px; }
    .rhythm-list p { border-bottom: 1px solid var(--line); display: grid; font-size: 12px; grid-template-columns: 125px 1fr; margin: 0; padding: 13px 0; }
    .rhythm-list strong { color: var(--clay-dark); }
    .rhythm-list span { color: var(--ink-soft); }
    .measurement { background: var(--forest); color: var(--white); padding: 56px 48px; }
    .measurement h2 { color: var(--white); }
    .measurement ul { list-style: none; margin: 27px 0 22px; padding: 0; }
